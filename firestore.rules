rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRoles() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', []);
    }

    function isAdmin() {
      return request.auth != null && (
        userRoles().hasAny(['admin', 'owner'])
        || (request.auth.token.email != null
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    function isOwner() {
      return request.auth != null && userRoles().hasAny(['owner']);
    }

    function isProvider() {
      return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', []).hasAny(['provider']);
    }

    function isSessionCoach(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.coachUid
             == request.auth.uid;
    }

    match /admins/{email} {
      allow read:  if isAdmin(); // admin list is not for general users
      allow write: if false;
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (request.auth != null
                        && request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['playerCount']));

      match /players/{playerId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == playerId;
        allow update: if isAdmin()
                      || (request.auth != null
                          && request.auth.uid == playerId
                          && request.resource.data.diff(resource.data)
                               .affectedKeys().hasOnly(['submittedScore', 'submittedRound']));
        allow delete: if isAdmin();
      }
    }

    // Valid session fields for client-written creates/updates (CF-managed fields excluded).
    function validSessionKeys() {
      return request.resource.data.keys().hasOnly([
        'date','time','venue','level','gender','type','description',
        'capacity','cost','coachFee','coachUid','coach',
        'providerUid','seriesId','seriesName','askPositions',
        'status','attendeeCount','waitingListCount','cancellationCount','createdAt',
      ]);
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if isAdmin()
                    || (isProvider()
                        && request.resource.data.providerUid == request.auth.uid
                        && validSessionKeys());
      allow delete: if isAdmin()
                    || (isProvider() && resource.data.providerUid == request.auth.uid);
      // attendeeCount / waitingListCount are written by Cloud Functions (Admin SDK) only
      allow update: if isAdmin()
                    || (isProvider() && resource.data.providerUid == request.auth.uid)
                    || (request.auth != null
                        && resource.data.coachUid == request.auth.uid
                        && request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['status', 'report']));
    }

    match /sessions/{sessionId}/attendees/{attendeeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == attendeeId;
      allow update: if request.auth != null && (
        isAdmin()
        || (request.auth.uid == attendeeId
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['positions']))
        || (isSessionCoach(sessionId)
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['present']))
      );
      allow delete: if request.auth != null
                    && (request.auth.uid == attendeeId || isAdmin());
    }

    match /sessions/{sessionId}/waitingList/{uid} {
      allow read: if request.auth != null;
      allow write: if false; // written only via Cloud Functions (Admin SDK)
    }

    match /venues/{venueId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /series/{seriesId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();

      match /registrations/{uid} {
        // members see only their own registration; admins see all
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if false; // written only via Cloud Functions (Admin SDK)
      }

      match /invites/{inviteId} {
        allow read:  if false; // validated server-side only (Admin SDK bypasses this)
        allow write: if isAdmin();
      }
    }

    // Public profiles — safe fields only, maintained by onUserWritten Cloud Function.
    match /publicProfiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if false; // Cloud Functions only
    }

    match /users/{uid} {
      // Full user docs are private — only readable by the user themselves, admins, or owners.
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin() || isOwner());
      allow create: if request.auth != null && request.auth.uid == uid;
      // Owners can update any field (including roles)
      allow update: if request.auth != null && isOwner();
      // Admins can update everything except roles (role changes go through Cloud Functions)
      allow update: if request.auth != null
                    && isAdmin()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles']);
      // Users can update their own safe profile fields (never roles or adminRequest)
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly([
                           'name','email','photoURL','updatedAt',
                           'gender','level','positions','coachRequest','providerRequest'
                         ]);
      allow delete: if isAdmin();

      match /sessions/{sessionId} {
        allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write:  if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    match /requestTokens/{tokenId} {
      allow read, write: if false; // server-side only
    }
  }
}
